[user]
  name = Thomas Charron
  email = thomas.charron@bitsighttech.com
[push]
  default = matching
[fetch]
  prune = true
[alias]
  lg = log --pretty=format:'%Cblue%h%Creset %cI - %Cgreen[%an]%Creset %s %d' --decorate -25
[core]
  editor = mvim
  pager = cat
  excludesfile = /Users/thomsacharron/.gitignore
